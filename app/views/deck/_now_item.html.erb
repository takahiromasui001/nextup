<turbo-frame id="now_item">
  <% if current_user.now_item %>
    <% item = current_user.now_item %>
    <div class="mb-2 p-3 bg-green-50 border border-green-200 rounded-lg">
      <div class="flex items-center justify-between gap-1 text-xs text-gray-500 mb-1">
        <div class="flex items-center gap-1">
          <% if item.action_type %>
            <span class="px-2 py-0.5 bg-gray-100 rounded-full"><%= I18n.t("enums.item.action_type.#{item.action_type}") %></span>
          <% end %>
          <% if item.time_bucket %>
            <span class="px-2 py-0.5 bg-gray-100 rounded-full"><%= I18n.t("enums.item.time_bucket.#{item.time_bucket}") %></span>
          <% end %>
        </div>
        <%= link_to edit_item_path(item, return_to: 'deck'), class: 'text-indigo-400 hover:text-indigo-600', data: { turbo_frame: '_top' } do %>
          <%= render 'shared/icon_edit' %>
        <% end %>
      </div>
      <p class="text-sm font-semibold"><%= render 'shared/item_title', item: item %></p>
      <% if item.memo.present? %>
        <p class="text-xs text-gray-500 mt-0.5 whitespace-pre-wrap"><%= item.memo %></p>
      <% end %>
      <div class="flex items-center justify-end gap-2 mt-2">
        <%= button_to '外す', deck_pin_path, method: :delete, params: { item_id: item.id },
              class: 'px-2 py-1 text-xs bg-white border border-gray-300 text-gray-600 rounded-full hover:bg-gray-50' %>
        <%= button_to '完了', deck_completions_path(item_id: item.id),
              class: 'px-2 py-1 text-xs bg-green-600 text-white rounded-full hover:bg-green-700' %>
      </div>
    </div>
  <% end %>
</turbo-frame>
