<div class="w-full max-w-md mx-auto pb-20">
  <%= turbo_frame_tag 'items_list' do %>
    <div class="flex border-b border-gray-200 mb-4">
      <% Item.statuses.keys.each do |key| %>
        <%= link_to I18n.t("enums.item.status.#{key}"), items_path(status: key),
              data: { turbo_action: 'advance' },
              class: "px-4 py-2 text-sm #{ key == @status ? 'border-b-2 border-indigo-600 text-indigo-600 font-medium' : 'text-gray-500 hover:text-gray-700' }" %>
      <% end %>
    </div>

    <% @items.each do |item| %>
      <%= render 'item', item: item %>
    <% end %>
    <% if @items.empty? %>
      <p class="text-gray-400 text-sm text-center py-8">アイテムがありません</p>
    <% end %>
  <% end %>
</div>
