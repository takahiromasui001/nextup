<div class="bg-white rounded-xl shadow-sm px-4 py-3 mb-2" data-controller="item-detail">
  <div class="flex items-center justify-between">
    <p class="text-sm font-medium text-gray-900 truncate flex-1"><%= item.title %></p>
    <div class="flex items-center gap-2 ml-2 shrink-0">
      <%= link_to edit_item_path(item), class: 'text-indigo-400 hover:text-indigo-600', data: { turbo_frame: '_top' } do %>
        <%= render 'shared/icon_edit' %>
      <% end %>
      <button data-action="item-detail#toggle" class="text-gray-400 hover:text-gray-600">
        <svg data-item-detail-target="icon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
    </div>
  </div>
  <div class="flex items-center gap-2 mt-1 text-xs text-gray-500">
    <span><%= I18n.t("enums.item.action_type.#{item.action_type}") %></span>
    <span>·</span>
    <span><%= I18n.t("enums.item.time_bucket.#{item.time_bucket}") %></span>
    <span class="ml-auto"><%= l(item.updated_at, format: :short) %></span>
  </div>

  <div data-item-detail-target="detail" class="hidden mt-3 pt-3 border-t border-gray-100 text-xs text-gray-700 space-y-1">
    <% if item.url.present? %>
      <p><a href="<%= item.url %>" target="_blank" class="text-blue-500 underline truncate block"><%= item.url %></a></p>
    <% end %>
    <% if item.memo.present? %>
      <p class="whitespace-pre-wrap"><%= item.memo %></p>
    <% end %>
    <div class="flex flex-wrap gap-2 mt-1 text-gray-500">
      <span><%= I18n.t("enums.item.energy.#{item.energy}") %></span>
      <span>·</span>
      <span><%= I18n.t("enums.item.status.#{item.status}") %></span>
      <span>·</span>
      <span><%= l(item.created_at, format: :short) %></span>
    </div>
  </div>
</div>
